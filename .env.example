OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
API_HOST=127.0.0.1
API_PORT=8000
RAG_API_BEARER_TOKEN=

PDF_DIR=data/pdfs
CHROMA_DIR=data/chroma
STATE_DIR=data/state
COLLECTION_NAME=pdf_rag
MODEL_CACHE_DIR=data/models

CHUNK_SIZE_WORDS=320
CHUNK_OVERLAP_WORDS=60
VECTOR_CANDIDATES=8
KEYWORD_CANDIDATES=8
RERANK_ENABLED=true
RERANK_CANDIDATES=12
RERANK_MODEL_NAME=jinaai/jina-reranker-v1-turbo-en
RERANK_MAX_CHARS=1800
OCR_ENABLED=true
OCR_MIN_TEXT_CHARS=120
OCR_IMAGE_AREA_THRESHOLD=0.55
OCR_RENDER_DPI=144
FINAL_CHUNKS=6
MAX_CONTEXT_CHUNKS=6
RESPONSE_MAX_TOKENS=700
TEMPERATURE=0.1
